{
  "openapi": "3.0.0",
  "info": { "title": "System Service API", "version": "1.0.0", "description": "System service routes with basic request/response schemas" },
  "servers": [{ "url": "/system" }],
  "paths": {
    "/health": { "get": { "summary": "Health", "responses": {"200": {"description": "OK","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Health"}}}} } },

    "/bootstrap": { "get": { "summary": "Bootstrap data", "responses": {"200": {"description": "Bootstrap","content":{"application/json":{"schema":{"type":"object","properties":{"features":{"type":"array","items":{"type":"string"}},"version":{"type":"string"}}}}}} } },

    "/packages": { "get": { "summary": "List packages", "responses": {"200": {"description": "Array of packages","content":{"application/json":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/Package"}}}}}} } },

    "/plans": { "get": { "summary": "List plans", "responses": {"200": {"description": "Array of plans","content":{"application/json":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/Plan"}}}}}} } },

    "/subscriptions": { "post": { "summary": "Create subscription", "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref":"#/components/schemas/SubscriptionRequest"}}}}, "responses": {"201": {"description": "Created","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Subscription"}}}},"400": {"description":"Bad request","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Error"}}}} } } },

    "/admin/plans": { "post": { "summary": "Admin create plan", "requestBody": {"required": true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/PlanInput"}}}}, "responses": {"201": {"description":"Created","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Plan"}}}} } },

    "/admin/packages": {
      "get": { "summary": "Admin list packages","responses":{"200":{"description":"OK","content":{"application/json":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/Package"}}}}}}},
      "post": { "summary": "Admin create package","requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/PackageInput"}}}},"responses":{"201":{"description":"Created","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Package"}}}}}}
    ,

    "/admin/microfrontends": { "post": { "summary": "Create microfrontend", "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref":"#/components/schemas/MicrofrontendInput"}}}}, "responses": {"201": {"description": "Created","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Microfrontend"}}}} } }
  },
  "components": {
    "schemas": {
      "Health": { "type": "object", "properties": { "status": { "type": "string" }, "service": { "type": "string" } }, "example": { "status": "ok", "service": "system-service" } },

      "Package": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "description": { "type": "string" } }, "required": ["id","name"] },
      "Plan": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "price": { "type": "number" } }, "required":["id","name"] },

      "SubscriptionRequest": { "type": "object", "properties": { "userId": { "type": "string" }, "planId": { "type": "string" } }, "required": ["userId","planId"] },
      "Subscription": { "type": "object", "properties": { "id": { "type": "string" }, "userId": { "type": "string" }, "planId": { "type": "string" }, "startedAt": { "type": "string", "format": "date-time" } }, "required": ["id","userId","planId"] },

      "PackageInput": { "type": "object", "properties": { "name": { "type": "string" }, "description": { "type": "string" } }, "required": ["name"] },
      "PlanInput": { "type": "object", "properties": { "name": { "type": "string" }, "price": { "type": "number" } }, "required": ["name"] },

      "MicrofrontendInput": { "type": "object", "properties": { "id": { "type": "string" }, "url": { "type": "string" } }, "required": ["id","url"] },
      "Microfrontend": { "type": "object", "properties": { "id": { "type": "string" }, "url": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" } } },

      "Error": { "type": "object", "properties": { "message": { "type": "string" } }, "example": { "message": "Invalid request" } }
    }
  }
}
